{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "Chess Mini",
  "version": "0.1.0",
  "identifier": "com.chess-mini.app",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:5173",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "windows": [
      {
        "title": "Chess Mini",
        "width": 900,
        "height": 640,
        "minWidth": 400,
        "minHeight": 300,
        "resizable": true,
        "fullscreen": false,
        "decorations": false,
        "transparent": false
      }
    ],
    "security": {
      "csp": {
        "default-src": "'self'",
        "style-src": "'self' 'unsafe-inline' https://api.fontshare.com https://fonts.googleapis.com",
        "font-src": "'self' https://api.fontshare.com https://fonts.gstatic.com data:",
        "img-src": "'self' asset: http://asset.localhost data:"
      }
    }
  },
  "bundle": {
    "active": true,
    "targets": ["nsis"],
    "createUpdaterArtifacts": true,
    "publisher": "sazardev",
    "copyright": "© 2026 sazardev",
    "license": "MIT",
    "licenseFile": "installer/SETUP.txt",
    "category": "Education",
    "shortDescription": "Minimalist chess analyzer & game journal",
    "longDescription": "Chess Mini is a fast, minimalist desktop app to record, analyze and review your chess games — engine analysis, move-quality marks, annotations, autosave and a searchable library.",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "windows": {
      "nsis": {
        "installMode": "currentUser",
        "installerIcon": "icons/icon.ico",
        "sidebarImage": "installer/sidebar.bmp"
      }
    }
  },
  "plugins": {
    "updater": {
      "endpoints": [
        "https://github.com/sazardev/chess-mini/releases/latest/download/latest.json"
      ],
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDc3RUExQjE0MjQ0RDdEN0YKUldSL2ZVMGtGQnZxZHcreEpZZ3BWVnh0NVVXMjBnMHd5Nk1HRWtxWlk1TjNUcUsrdFQ2REFxL3IK"
    }
  }
}
